---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@/utils/styles";
import TextArea from "./TextArea.astro";
import { labelBaseClass } from "@/styles/components/input";

interface Props extends HTMLAttributes<"textarea"> {
  label: string;
  containerClassName?: string;
  inputClassName?: string;
  labelClassName?: string;
}

const { label, containerClassName = "", inputClassName = "", labelClassName = "", ...inputProps } = Astro.props;
---

<div class={cn("relative", containerClassName)}>
  <TextArea className={inputClassName} {...inputProps} />
  <label class={cn(labelBaseClass, labelClassName)}>
    {label}
  </label>
</div>